@@ -0,0 +1,105 @@
+using System;
+using System.Collections.Generic;
+using System.Net;
+using System.Threading;
+using System.Threading.Tasks;
+using Distribt.Services.Orders.Aggregates;
+using Distribt.Services.Orders.Data;
+using Distribt.Services.Orders.Dto;
+using Distribt.Services.Orders.Events;
+using Distribt.Services.Orders.Services;
+using Moq;
+using Xunit;
+
+namespace Distribt.Tests.Services.Orders.BusinessLogic.Services;
+
+public class TestOrderCancelledService
+{
+    [Fact]
+    public async Task WhenOrderCanBeCancelled_ThenOrderIsCancelledAndSaved()
+    {
+        OrderDetails orderDetails = CreateOrder();
+        Mock<IOrderRepository> repository = CreateRepository(orderDetails);
+        OrderCancelledService service = new OrderCancelledService(repository.Object);
+
+        var result = await service.Execute(orderDetails.Id);
+
+        Assert.True(result.Success);
+        Assert.Equal(OrderStatus.Cancelled, orderDetails.Status);
+        repository.Verify(a => a.Save(orderDetails, It.IsAny<CancellationToken>()), Times.Once);
+    }
+
+    [Fact]
+    public async Task WhenOrderDoesNotExist_ThenNotFoundIsReturned()
+    {
+        Mock<IOrderRepository> repository = CreateRepository(null);
+        OrderCancelledService service = new OrderCancelledService(repository.Object);
+
+        var result = await service.Execute(Guid.NewGuid());
+
+        Assert.False(result.Success);
+        Assert.Equal(HttpStatusCode.NotFound, result.HttpStatusCode);
+        repository.Verify(a => a.Save(It.IsAny<OrderDetails>(), It.IsAny<CancellationToken>()), Times.Never);
+    }
+
+    [Theory]
+    [InlineData(OrderStatus.Dispatched)]
+    [InlineData(OrderStatus.Completed)]
+    public async Task WhenOrderIsAlreadyDispatchedOrDelivered_ThenConflictIsReturned(OrderStatus status)
+    {
+        OrderDetails orderDetails = CreateOrder(status);
+        Mock<IOrderRepository> repository = CreateRepository(orderDetails);
+        OrderCancelledService service = new OrderCancelledService(repository.Object);
+
+        var result = await service.Execute(orderDetails.Id);
+
+        Assert.False(result.Success);
+        Assert.Equal(HttpStatusCode.Conflict, result.HttpStatusCode);
+        Assert.Equal(status, orderDetails.Status);
+        repository.Verify(a => a.Save(It.IsAny<OrderDetails>(), It.IsAny<CancellationToken>()), Times.Never);
+    }
+
+    [Fact]
+    public async Task WhenOrderIsAlreadyCancelled_ThenNoAdditionalSaveIsRequired()
+    {
+        OrderDetails orderDetails = CreateOrder(OrderStatus.Cancelled);
+        Mock<IOrderRepository> repository = CreateRepository(orderDetails);
+        OrderCancelledService service = new OrderCancelledService(repository.Object);
+
+        var result = await service.Execute(orderDetails.Id);
+
+        Assert.True(result.Success);
+        Assert.Equal(OrderStatus.Cancelled, orderDetails.Status);
+        repository.Verify(a => a.Save(It.IsAny<OrderDetails>(), It.IsAny<CancellationToken>()), Times.Never);
+    }
+
+    private static Mock<IOrderRepository> CreateRepository(OrderDetails? orderDetails)
+    {
+        Mock<IOrderRepository> repository = new Mock<IOrderRepository>();
+        repository.Setup(a => a.GetByIdOrDefault(It.IsAny<Guid>(), It.IsAny<CancellationToken>()))
+            .ReturnsAsync(orderDetails);
+
+        return repository;
+    }
+
+    private static OrderDetails CreateOrder(OrderStatus status = OrderStatus.Created)
+    {
+        OrderDetails orderDetails = new OrderDetails(Guid.NewGuid());
+        orderDetails.Apply(new OrderCreated(
+            new DeliveryDetails("Street", "City", "Country"),
+            new PaymentInformation("4111111111111111", "12/30", "123"),
+            new List<ProductQuantity> { new ProductQuantity(1, 1) }));
+
+        if (status == OrderStatus.Dispatched)
+            orderDetails.Apply(new OrderDispatched());
+
+        if (status == OrderStatus.Completed)
+            orderDetails.Apply(new OrderCompleted());
+
+        if (status == OrderStatus.Cancelled)
+            orderDetails.Apply(new OrderCancelled());
+
+        orderDetails.MarkChangesAsCommitted();
+        return orderDetails;
+    }
+}
